<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Handle bar untuk swipe -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/slate_divider"
        android:alpha="0.5" />

    <!-- Logo + nama toko -->
    <ImageView
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@string/desc_logo"
        android:src="@drawable/ic_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="6dp"
        android:text="@string/receipt_store_name"
        android:textColor="@color/slate_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/receipt_store_tagline"
        android:textColor="@color/slate_text_secondary"
        android:textSize="11sp" />

    <!-- Garis putus-putus ala struk -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/dashed_line" />

    <!-- Nomor nota & tanggal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvReceiptNumber"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:textColor="@color/slate_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvReceiptDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/slate_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Info perangkat & pelanggan -->
    <TextView
        android:id="@+id/tvReceiptDevice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/slate_text"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvReceiptCustomer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/slate_text_secondary"
        android:textSize="13sp" />

    <!-- Garis putus-putus -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/dashed_line" />

    <!-- Header rincian -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/receipt_detail_header"
        android:textColor="@color/slate_text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.15" />

    <!-- Baris: Suku Cadang -->
    <LinearLayout
        android:id="@+id/rowSparepart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/receipt_sparepart"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvSparepartValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Baris: Garansi & QC -->
    <LinearLayout
        android:id="@+id/rowRiskFund"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/receipt_risk_fund"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvRiskFundValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Baris: Bahan Penunjang -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/receipt_operational"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvOperationalValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Baris: Jasa Teknisi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvServiceFeeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvServiceFeeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/slate_text"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Garis putus-putus sebelum total -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/dashed_line" />

    <!-- HERO TOTAL: Card khusus menonjol -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/hero_total_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/receipt_total"
            android:textColor="@color/slate_text"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTotalValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/green_total"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Pesan edukasi -->
    <TextView
        android:id="@+id/tvWarrantyMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@color/blue_light"
        android:padding="12dp"
        android:textColor="@color/slate_text"
        android:textSize="12sp"
        android:lineSpacingExtra="2dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:text="@string/receipt_footer_thanks"
        android:textColor="@color/slate_text_secondary"
        android:textSize="12sp" />

    <!-- Garis putus-putus penutup struk -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/dashed_line" />

    <!-- Tombol aksi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShare"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="@string/btn_share_receipt"
            app:icon="@drawable/ic_share"
            app:iconSize="18dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/btn_done" />
    </LinearLayout>
</LinearLayout>
